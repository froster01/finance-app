# Database
DATABASE_URL=postgres://postgres:password@db:5432/finance_app_development

# Redis
REDIS_URL=redis://redis:6379/0

# Rails Environment
RAILS_ENV=development

# Secret Key Base (generate with: docker compose run --rm app bundle exec rails secret)
SECRET_KEY_BASE=your_secret_key_base_here

# Mailer Settings (for Devise)
ACTION_MAILER_DEFAULT_URL_OPTIONS_HOST=localhost
ACTION_MAILER_DEFAULT_URL_OPTIONS_PORT=3000
